
DATABASE_URL="postgresql://postgres:password@localhost:5432/momentum"

# ---- App URL ----

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Corsair ----

CORSAIR_KEK=""
TENANT_ID="dev"


BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""




# ---- OpenAI (AI triage, catch-me-up, ⌘K agent) ----
# Unset = AI features degrade gracefully (no triage/digest) but the app runs.
OPENAI_API_KEY=""

# ---- Inngest (background AI jobs) ----
# Local: run `pnpm inngest:dev` (no keys needed).  Production: set both.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ---- Razorpay (billing / Pro subscriptions) ----

RAZORPAY_KEY_ID=""              # rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=""          # xxxxxxxxxxxxxxxx
RAZORPAY_PLAN_ID=""             # a monthly Plan you create in the dashboard
RAZORPAY_WEBHOOK_SECRET=""      # set when you register the webhook endpoint

# Razorpay — browser (safe to expose). Set when billing is enabled.
NEXT_PUBLIC_RAZORPAY_KEY_ID=""  # rzp_test_xxxxxxxx
