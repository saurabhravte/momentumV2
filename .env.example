# ─────────────────────────────────────────────────────────────────────────────
# Momentum environment.  Copy to `.env` for local dev; set the same keys in your
# host's dashboard (e.g. Vercel → Project → Settings → Environment Variables)
# for production.  Only the REQUIRED block is needed to boot the app.
# ─────────────────────────────────────────────────────────────────────────────

# ==== REQUIRED ====

# ---- Database (Postgres) ----
# Local: use ./start-database.sh (Docker).  Free hosted: Neon (neon.tech) —
# copy the pooled connection string.
DATABASE_URL="postgresql://postgres:password@localhost:5432/momentum"

# ---- App URL ----
# Local: http://localhost:3000.  Production: your deployed origin (no trailing slash).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Corsair ----
# base64 key-encryption key — generate with: openssl rand -base64 32
CORSAIR_KEK=""
TENANT_ID="dev"

# ---- Better Auth (Google sign-in) ----
# BETTER_AUTH_SECRET: openssl rand -base64 32
# BETTER_AUTH_URL must match your origin (http://localhost:3000 locally,
# https://your-app.vercel.app in prod).  Add the same origin's
# /api/auth/callback/google as an authorized redirect URI in Google Cloud Console.
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# ==== OPTIONAL ====

# ---- OpenAI (AI triage, catch-me-up, ⌘K agent) ----
# Unset = AI features degrade gracefully (no triage/digest) but the app runs.
OPENAI_API_KEY=""

# ---- Inngest (background AI jobs) ----
# Local: run `pnpm inngest:dev` (no keys needed).  Production: set both.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ---- Razorpay (billing / Pro subscriptions) ----
# Unset = billing disabled; the app runs free-only and upgrade UI is inert.
# Set ALL FOUR server keys + the public key id to enable payments.
RAZORPAY_KEY_ID=""              # rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=""          # xxxxxxxxxxxxxxxx
RAZORPAY_PLAN_ID=""             # a monthly Plan you create in the dashboard
RAZORPAY_WEBHOOK_SECRET=""      # set when you register the webhook endpoint

# Razorpay — browser (safe to expose). Set when billing is enabled.
NEXT_PUBLIC_RAZORPAY_KEY_ID=""  # rzp_test_xxxxxxxx
