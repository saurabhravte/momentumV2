# ---- Database (Postgres) ----
DATABASE_URL="postgresql://postgres:password@localhost:5432/momentum"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Corsair ----
# base64 key encryption key — generate with: openssl rand -base64 32
CORSAIR_KEK=""
TENANT_ID="dev"

# ---- Better Auth (Google sign-in) ----
# generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- OpenAI (AI triage, catch-me-up, ⌘K agent) ----
OPENAI_API_KEY=""

# ---- Inngest (optional locally — use `npx inngest-cli dev`) ----
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""


# Razorpay — server
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_PLAN_ID=plan_xxxxxxxxxxxx          # a monthly Plan you create in the dashboard
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxx      # set when you register the webhook

# Razorpay — browser
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx